{
  "name": "ltcpa-website",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "fetch-cms": "node scripts/fetch-cms.js",
    "build:admin-css": "tailwindcss -i ./styles/admin.css -o ./public/admin/admin.css --minify",
    "build": "npm run build:admin-css && npm run fetch-cms && next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit"
